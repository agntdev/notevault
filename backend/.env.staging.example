# Staging environment variables for the NoteVault backend.
# Real values live in GitHub Actions secrets (STAGING_*) — this file is a
# copy-into-the-deploy-host template that documents what the service needs.

NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# Postgres. Use a managed instance with TLS in real deployments.
DATABASE_URL=postgres://notevault:CHANGE_ME@db.internal:5432/notevault

# JWT secret — at least 16 characters. Rotate via the secret manager;
# rotating invalidates all outstanding tokens by design.
JWT_SECRET=CHANGE_ME_TO_A_32_PLUS_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=24h

# Only the exact origin is allowed. Set CORS_ORIGIN to the frontend URL.
CORS_ORIGIN=https://staging.notevault.example.com
